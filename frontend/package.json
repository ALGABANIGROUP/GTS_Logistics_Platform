{
  "name": "gts-tailwind-starter",
  "version": "1.0.0-rc.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "npm run lint:stage-base && npm run lint:stage-routes && npm run lint:stage-hooks-general && npm run lint:stage-next-services",
    "lint:stage-base": "eslint src/api/paymentApi.js \"src/__tests__/**/*.{js,jsx}\" \"src/test/**/*.{js,jsx}\" --max-warnings 0",
    "lint:stage-routes": "eslint \"src/routes/**/*.{js,jsx}\" --max-warnings 0",
    "lint:stage-hooks-general": "eslint \"src/hooks/**/*.{js,jsx}\" --max-warnings 0",
    "lint:stage-next-services": "eslint \"src/services/**/*.{js,jsx}\" --max-warnings 0",
    "lint:full": "eslint . --ext js,jsx",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run test:run && npm run build",
    "preview": "vite preview",
    "start": "vite"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hcaptcha/react-hcaptcha": "^1.17.4",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@sentry/react": "^8.55.0",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.31.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.539.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.12.0",
    "react-toastify": "^11.0.5",
    "recharts": "^3.7.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.10"
  }
}
