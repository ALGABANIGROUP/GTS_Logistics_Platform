# production frontend domain
VITE_APP_URL=https://www.gtsdispatcher.com
VITE_APP_DOMAIN=https://www.gtsdispatcher.com

# production backend origin
VITE_API_BASE_URL=https://api.gtsdispatcher.com
VITE_API_URL=https://api.gtsdispatcher.com
VITE_WS_BASE_URL=wss://api.gtsdispatcher.com/api/v1/ws

# Sentry Configuration (optional - for error monitoring)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.0
VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=0.1

# Google Analytics / Search Console (optional)
VITE_GA_MEASUREMENT_ID=
VITE_GOOGLE_SITE_VERIFICATION=
