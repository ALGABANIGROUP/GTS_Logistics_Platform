# ===========================
# GTS Logistics - .gitignore
# ===========================

# --- Python Environments ---
.venv/
env/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Environment Variables ---
# Backend environment files
.env
.env.production
.env.staging
.env.local
.env.*.local

# Frontend environment files
frontend/.env
frontend/.env.production
frontend/.env.staging
frontend/.env.local
frontend/.env.*.local

# Allow template files
!.env.example
!frontend/.env.example

.envrc

# --- Databases / Logs / Cache ---
*.db
*.sqlite
*.sqlite3
*.log
*.out
*.err
logs/
cache/
.tmp/
.cache/
*.bak

# --- Alembic / Migrations ---
alembic/versions/__pycache__/
alembic/versions/*.pyc
alembic/versions/*.bak
alembic/__pycache__/

# --- Node / Frontend ---
node_modules/
dist/
build/
*.map
.vite/
.vscode/
.idea/
*.code-workspace

# --- Uploads and Temporary Files ---
uploads/
temp/
tmp/
*.tmp
*.temp

# --- API Keys and Secrets ---
secrets.json
config/secrets.json
*.pem
*.key
*.crt
*.cer

# --- Performance Analysis ---
*.mem
memsnap_*.pkl
performance_*.json
security_*.json

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- IDE and Editor Files ---
*.swp
*.swo
*~
.vscode/settings.json
.idea/

# --- Build and Distribution ---
build/
dist/
*.spec
*.egg-info/

# --- Documentation Generated ---
docs/_build/
docs/build/

# --- Search and AI Data ---
search-index/
*.idx
ai-bot-data/
bot-configs/

# --- Carrier and API Keys ---
carrier-api-keys/
api-keys/

# --- Test Files ---
test_*.py
*_test.py
tests/
.pytest_cache/
.coverage
htmlcov/

# --- Docker ---
.dockerignore

# --- Backup Files ---
*.backup
*~

# --- Reports / Generated files ---
*.pdf
*.csv
*.xlsx
*.zip
*.tar
*.gz

# --- OS / System files ---
.DS_Store
Thumbs.db
desktop.ini
GTS_Logistics_Platform/

# --- Render / Neon / Host-specific ---
*.render.log
*.neon.log
.neon/
.render/
.deploy/

# --- Local Dev Tools ---
tools/gts_profile.ps1
tools/auto_activate_gts.ps1
Desktop/
Documents/
*.lnk

# --- Test & Coverage ---
.coverage
.pytest_cache/
.mypy_cache/
htmlcov/
.tox/

# --- Temporary files ---
~$*
*.swp
*.swo
*.tmp
.tmp_run_uvicorn.py
# --- Compiled / Runtime artifacts ---
*.exe
*.pem
*.key
*.crt
*.pfx
secrets/

# --- Backups / Dumps ---
backups/
*.sql

# --- Local sensitive scratch files ---
secrets.txt
_leak_blob.txt
backend/routes/auth_old.py

# --- Uploads ---
uploads/
backend/uploads/
frontend/uploads/

# --- Python cache anywhere ---
**/__pycache__/
**/*.pyc
