+    def _generate_plan_invoice_number(self, user_id: int, plan_code: str) -> str:
+        ts = datetime.utcnow().strftime("%Y%m%d%H%M%S")
+        suffix = str(uuid4()).split("-")[0].upper()
+        safe_plan = re.sub(r"[^A-Z0-9_]", "", plan_code.upper()) or "UNKNOWN"
+        return f"{self._PLAN_INVOICE_PREFIX}-{safe_plan}-U{int(user_id)}-{ts}-{suffix}"
+
+    def _parse_plan_invoice_number(self, number: str) -> Optional[Dict[str, Optional[str]]]:
+        if not number or not number.startswith(f"{self._PLAN_INVOICE_PREFIX}-"):
+            return None
+        parts = number.split("-")
+        if len(parts) < 5:
+            return None
+        plan_code = parts[1]
+        user_part = parts[2]
+        user_id = None
+        if user_part.startswith("U") and user_part[1:].isdigit():
+            user_id = int(user_part[1:])
+        return {"plan_code": plan_code, "user_id": user_id}
+
+    def _current_cycle_start(self, at: Optional[datetime] = None) -> date:
+        now = at or datetime.utcnow()
+        return date(year=now.year, month=now.month, day=1)
+
+    def _next_cycle_start(self, at: Optional[datetime] = None) -> date:
+        now = at or datetime.utcnow()
+        year = now.year + (1 if now.month == 12 else 0)
+        month = 1 if now.month == 12 else now.month + 1
+        return date(year=year, month=month, day=1)
+
+    async def create_plan_invoice(
+        self,
+        user_id: int,
+        plan_code: str,
+        amount_usd: float,
+        status: str = "pending",
+        invoice_date: Optional[datetime] = None,
+    ) -> Invoice:
+        try:
+            normalized_plan = re.sub(r"[^A-Z0-9_]", "", (plan_code or "").upper()) or "UNKNOWN"
+            invoice = Invoice(
+                number=self._generate_plan_invoice_number(user_id=user_id, plan_code=normalized_plan),
+                date=(invoice_date or datetime.utcnow()).date(),
+                amount_usd=float(amount_usd),
+                status=(status or "pending"),
+                plan_code=normalized_plan,
+                user_id=int(user_id),
+                shipment_id=None,
+            )
+            self.db.add(invoice)
+            await self.db.flush()
+            await self.db.commit()
+            logger.info(
+                "✅ Plan invoice created: id=%s plan=%s user=%s amount=%s",
+                invoice.id,
+                plan_code,
+                user_id,
+                amount_usd,
+            )
+            return invoice
+        except Exception as e:
+            logger.error(f"❌ Failed to create plan invoice: {str(e)}")
+            await self.db.rollback()
+            raise
+
+    async def ensure_subscription_cycle_invoice(
+        self,
+        user_id: int,
+        plan_code: str,
+        amount_usd: float,
+        cycle_date: Optional[datetime] = None,
+        status: str = "pending",
+    ) -> Invoice:
+        try:
+            normalized_plan = re.sub(r"[^A-Z0-9_]", "", (plan_code or "").upper()) or "UNKNOWN"
+            base_date = cycle_date or datetime.utcnow()
+            cycle_start = self._current_cycle_start(base_date)
+            next_cycle_start = self._next_cycle_start(base_date)
+
+            existing_stmt = (
+                select(Invoice)
+                .where(
+                    Invoice.user_id == int(user_id),
+                    Invoice.plan_code == normalized_plan,
+                    Invoice.date >= cycle_start,
+                    Invoice.date < next_cycle_start,
+                )
+                .order_by(Invoice.created_at.desc())
+            )
+            existing = (await self.db.execute(existing_stmt)).scalars().first()
+            if existing:
+                return existing
+
+            return await self.create_plan_invoice(
+                user_id=int(user_id),
+                plan_code=normalized_plan,
+                amount_usd=float(amount_usd),
+                status=status,
+                invoice_date=base_date,
+            )
+        except Exception as e:
+            logger.error(f"❌ Failed to ensure subscription cycle invoice: {str(e)}")
+            raise
+
+    async def list_plan_invoices(
+        self,
+        user_id: Optional[int] = None,
+        plan_code: Optional[str] = None,
+        status: Optional[str] = None,
+        from_date: Optional[date] = None,
+        to_date: Optional[date] = None,
+        limit: int = 50,
+        offset: int = 0,
+    ) -> Tuple[List[Invoice], int]:
+        try:
+            stmt = select(Invoice).where(
+                or_(
+                    Invoice.plan_code.is_not(None),
+                    Invoice.number.like(f"{self._PLAN_INVOICE_PREFIX}-%"),
+                )
+            )
+            if status:
+                stmt = stmt.where(Invoice.status == status)
+            if from_date:
+                stmt = stmt.where(Invoice.date >= from_date)
+            if to_date:
+                stmt = stmt.where(Invoice.date <= to_date)
+
+            normalized_plan = (plan_code or "").upper().strip() or None
+            if user_id is not None:
+                stmt = stmt.where(Invoice.user_id == int(user_id))
+            if normalized_plan:
+                stmt = stmt.where(Invoice.plan_code == normalized_plan)
+
+            stmt = stmt.order_by(Invoice.created_at.desc())
+            rows = (await self.db.execute(stmt)).scalars().all()
+
+            filtered: List[Invoice] = []
+            for inv in rows:
+                if inv.plan_code and inv.user_id is not None:
+                    filtered.append(inv)
+                    continue
+
+                parsed = self._parse_plan_invoice_number(inv.number)
+                if not parsed:
+                    continue
+
+                parsed_user_id = parsed.get("user_id")
+                parsed_plan = parsed.get("plan_code")
+                if user_id is not None and parsed_user_id != int(user_id):
+                    continue
+                if normalized_plan and parsed_plan != normalized_plan:
+                    continue
+
+                inv.user_id = int(parsed_user_id) if parsed_user_id is not None else None
+                inv.plan_code = parsed_plan
+                filtered.append(inv)
+
+            total = len(filtered)
+            paginated = filtered[offset : offset + limit]
+            return paginated, total
+        except Exception as e:
+            logger.error(f"❌ Failed to list plan invoices: {str(e)}")
+            return [], 0
+
+    async def get_plan_invoice_summary(
+        self,
+        user_id: Optional[int] = None,
+        from_date: Optional[date] = None,
+        to_date: Optional[date] = None,
+    ) -> Dict[str, Dict[str, float]]:
+        invoices, _ = await self.list_plan_invoices(
+            user_id=user_id,
+            from_date=from_date,
+            to_date=to_date,
+            limit=10000,
+            offset=0,
+        )
+        summary: Dict[str, Dict[str, float]] = {}
+        for inv in invoices:
+            plan = inv.plan_code
+            if not plan:
+                parsed = self._parse_plan_invoice_number(inv.number)
+                if not parsed:
+                    continue
+                plan = parsed.get("plan_code") or "UNKNOWN"
+            if plan not in summary:
+                summary[plan] = {
+                    "count": 0,
+                    "total_amount_usd": 0.0,
+                    "paid_count": 0,
+                    "pending_count": 0,
+                }
+            summary[plan]["count"] += 1
+            summary[plan]["total_amount_usd"] += float(inv.amount_usd or 0)
+            status_value = (inv.status or "").lower()
+            if status_value == "paid":
+                summary[plan]["paid_count"] += 1
+            elif status_value == "pending":
+                summary[plan]["pending_count"] += 1
+
+        return summary
+
