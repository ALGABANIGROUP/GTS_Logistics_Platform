+    amount = _resolve_plan_amount(plan)
+    payment_service = PaymentService(db, sudapay_service=None)
+    invoice = await payment_service.ensure_subscription_cycle_invoice(
+        user_id=int(user_id),
+        plan_code=plan_code,
+        amount_usd=amount,
+        status="pending",
+    )
+    return {
+        "invoice_id": invoice.id,
+        "invoice_number": invoice.number,
+        "plan_code": invoice.plan_code or plan_code,
+        "amount_usd": float(invoice.amount_usd),
