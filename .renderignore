# Render Build Optimization - Paths that don't trigger builds
# This file reduces build times by ignoring irrelevant file changes

# ============================================================
# Documentation & Guides (Ignore for builds)
# ============================================================
docs/
*.md
README.md
CHANGELOG.md
AI_*.md
*.txt
*.json
!requirements.txt
!package.json
!package-lock.json

# ============================================================
# Tests & Test Files (Ignore for production builds)
# ============================================================
tests/
test_*.py
*_test.py
pytest.ini
.pytest_cache/
__pycache__/
*.pyc
*.pyo

# ============================================================
# Development Files
# ============================================================
.venv/
venv/
.env.local
.env.development
.env.*.local
*.log
bootstrap_log.txt

# ============================================================
# IDE & Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store

# ============================================================
# Temporary & Cache Files
# ============================================================
.tmp_*
_archive/
_trash_*/
node_modules/
.pip_cache/

# ============================================================
# Git & Version Control
# ============================================================
.git/
.github/
.husky/
.pre-commit-config.yaml
.gitattributes
.gitignore

# ============================================================
# Analysis & Audit Files
# ============================================================
audit/
reports/
certification_report.*
pip_audit_*.json
security_audit.json
detect_secrets_scan.json

# ============================================================
# Build Artifacts
# ============================================================
dist/
build/
*.egg-info/

# ============================================================
# Git & CI/CD
# ============================================================
.git/
.gitignore
.github/
.gitlab-ci.yml
.circleci/

# ============================================================
# Logs & Temp
# ============================================================
logs/
*.log
tmp/
temp/
*.tmp

# ============================================================
# Build Artifacts
# ============================================================
dist/
build/
*.egg

# ============================================================
# NodeJS (Frontend dependencies)
# ============================================================
node_modules/
package-lock.json
npm-shrinkwrap.json

# ============================================================
# Database Files
# ============================================================
*.db
*.sqlite
*.sqlite3
gts.db

# ============================================================
# Misc
# ============================================================
_trash_*
*.bak
*.backup
_old/
legacy/
deprecated/
