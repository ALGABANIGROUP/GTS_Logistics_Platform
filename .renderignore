# Render Build Optimization - Paths that don't trigger builds
# This file reduces build times by ignoring irrelevant file changes

# ============================================================
# Frontend (Not needed for backend builds)
# ============================================================
frontend/
frontend/**

# ============================================================
# Documentation & Guides
# ============================================================
docs/
*.md
README.md
CHANGELOG.md
AI_*.md

# ============================================================
# Tests & Test Files
# ============================================================
tests/
test_*.py
*_test.py
pytest.ini
.pytest_cache/

# ============================================================
# Development Files
# ============================================================
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.env.local
.env.development
.env.*.local

# ============================================================
# IDE & Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store

# ============================================================
# Git & CI/CD
# ============================================================
.git/
.gitignore
.github/
.gitlab-ci.yml
.circleci/

# ============================================================
# Logs & Temp
# ============================================================
logs/
*.log
tmp/
temp/
*.tmp

# ============================================================
# Build Artifacts
# ============================================================
dist/
build/
*.egg

# ============================================================
# NodeJS (Frontend dependencies)
# ============================================================
node_modules/
package-lock.json
npm-shrinkwrap.json

# ============================================================
# Database Files
# ============================================================
*.db
*.sqlite
*.sqlite3
gts.db

# ============================================================
# Misc
# ============================================================
_trash_*
*.bak
*.backup
_old/
legacy/
deprecated/
