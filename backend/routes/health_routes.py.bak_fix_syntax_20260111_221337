# backend/routes/health_routes.py

from __future__ import annotations

from typing import Any, Dict, Optional

from fastapi import APIRouter, Depends
from sqlalchemy import text
from sqlalchemy.ext.asyncio import AsyncSession

router = APIRouter(prefix="/health", tags=["Health"])


# -----------------------------------------------------------------------------
# Helpers: DB session (direct ping for finance + overall DB health)
# -----------------------------------------------------------------------------
def _try_import_async_session():
    """
    Attempts to import the project's async session factory.
    We avoid importing "async_ping" because it is duplicated/missing in some layouts.
    """
    try:
from backend.database.session import get_async_session  # type: ignore

        return get_async_session
    except Exception:
        try:
from backend.database.session import get_async_session  # type: ignore

            return get_async_session
        except Exception:
            return None


_session_dep = _try_import_async_session()
if _session_dep is None:
    async def _missing_session() -> Optional[AsyncSession]:
        return None

    _session_dep = _missing_session


# -----------------------------------------------------------------------------
# Helpers: Documents router presence (no auth calls)
# -----------------------------------------------------------------------------
def _documents_router_loaded() -> Dict[str, Any]:
    """
    Health check for documents subsystem without calling protected endpoints.
    We only confirm the module/router can be imported (service is present).
    """
    try:
        # documents_routes is the canonical module that defines:
        #   router (CRUD) + ai_router (AI endpoints)
from backend.routes.documents_routes import router as _docs_router  # type: ignore

        return {
            "ok": True,
            "loaded": True,
            "routes_prefix": getattr(_docs_router, "prefix", "/documents"),
        }
    except Exception as e1:
        try:
from backend.routes.documents_routes import router as _docs_router  # type: ignore

            return {
                "ok": True,
                "loaded": True,
                "routes_prefix": getattr(_docs_router, "prefix", "/documents"),
            }
        except Exception as e2:
            return {
                "ok": False,
                "loaded": False,
                "error": f"documents_routes import failed: {e1} | {e2}",
            }


# -----------------------------------------------------------------------------
# Routes
# -----------------------------------------------------------------------------
@router.get("/ping")
async def ping() -> Dict[str, Any]:
    return {"ok": True, "service": "gts-backend"}


@router.get("/full")
async def full_health(db: Optional[AsyncSession] = Depends(_session_dep)) -> Dict[str, Any]:
    services: Dict[str, Any] = {}

    # --- Finance / DB check: direct SELECT 1 ---
    if db is None:
        services["finance"] = {
            "ok": False,
            "error": "get_async_session not available",
            "hint": "Expected backend.database.session.get_async_session",
        }
    else:
        try:
            res = await db.execute(text("SELECT 1"))
            val = res.scalar()
            services["finance"] = {"ok": (val == 1), "db_ok": (val == 1)}
        except Exception as e:
            services["finance"] = {"ok": False, "error": str(e)}

    # --- Documents check: module/router presence (no auth, no internal HTTP) ---
    services["documents"] = _documents_router_loaded()

    overall_ok = all(
        isinstance(v, dict) and bool(v.get("ok"))
        for v in services.values()
    )

    return {"ok": overall_ok, "services": services}



