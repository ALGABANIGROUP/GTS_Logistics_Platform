            logger.warning("[bots] In policy but NOT registered: %s", missing_in_registry)
        if missing_in_policy:
            logger.warning("[bots] Registered but NOT in policy: %s", missing_in_policy)
    except Exception as e:
        logger.debug("[bots] registry/policy check skipped: %s", e)

    session_factory = _async_session_ctx or _get_async_session
    if ensure_bot_identities is not None and session_factory is not None:
        try:
            async with wrap_session_factory(session_factory) as session:
                await ensure_bot_identities(session)
            print("[startup] bot identities ensured")
        except Exception as e:
            print(f"[startup] WARN: ensure_bot_identities failed: {e}")

    try:
        from backend.bots import init_bot_os  # type: ignore

        if session_factory is not None:
            bot_os = init_bot_os(
                bot_names_provider=lambda: list(ai_registry.list().keys()),
                bot_getter=ai_registry.get,
                session_factory=session_factory,
            )
            await bot_os.start()
            app.state.bot_os = bot_os
            print("[startup] bot_os started")
    except Exception as e:
        print(f"[startup] WARN: bot_os init failed: {e}")

    # TODO: email mailbox provisioning disabled for now (fixing startup hang)
    # if ensure_system_mailboxes is not None and session_factory is not None:
