CANDIDATE_DB_KEYS = [
    "ASYNC_DATABASE_URL",
    "DATABASE_URL",
    "SQLALCHEMY_DATABASE_URL",
    "DB_URL",
]


def _ensure_ssl(url: str) -> str:
    def _has_qs(u: str) -> bool:
        return "?" in u

    def _append(u: str, part: str) -> str:
        sep = "&" if _has_qs(u) else "?"
        return f"{u}{sep}{part}"

    def _strip_flags(u: str) -> str:
        for token in ("ssl=true", "ssl=false"):
            u = (
                u.replace(f"&{token}", "")
                .replace(f"?{token}&", "?")
                .replace(f"?{token}", "?")
            )
        import re as _re

        if _has_qs(u):
            base, qs = u.split("?", 1)
            parts = [p for p in qs.split("&") if p and not _re.match(r"^sslmode=", p, flags=_re.I)]
            qs = "&".join(parts)
            u = base + (f"?{qs}" if qs else "")
        if u.endswith("?") or u.endswith("&"):
            u = u[:-1]
        return u

    url = _strip_flags(url)

    if url.startswith("postgresql+asyncpg://"):
        if "ssl=" not in url:
            url = _append(url, "ssl=require")
        return url

    if url.startswith("postgresql+psycopg://") or url.startswith("postgresql://"):
        if "sslmode=" not in url:
            url = _append(url, "sslmode=require")
        return url

    return url


def _mk_async(url: str) -> str:
    if url.startswith("postgresql+asyncpg://"):
        return _ensure_ssl(url)
    if url.startswith("postgresql+psycopg://"):
        core = url[len("postgresql+psycopg://") :]
        async_url = "postgresql+asyncpg://" + core
        return _ensure_ssl(async_url)
    if url.startswith("postgresql://"):
        url = "postgresql+asyncpg://" + url[len("postgresql://") :]
        return _ensure_ssl(url)
    return url


def _resolve_db_url() -> Optional[str]:
    db_url: Optional[str] = None
    for k in CANDIDATE_DB_KEYS:
        v = os.getenv(k)
        if v and v.strip():
            db_url = v.strip()
            break
    if not db_url:
        return None
    if db_url.startswith("postgresql"):
        db_url = _ensure_ssl(db_url)
        if db_url.startswith("postgresql://") or db_url.startswith("postgresql+psycopg://"):
            db_url = _mk_async(db_url)
    return db_url


def _normalize_db_env() -> None:
    async_url = os.getenv("ASYNC_DATABASE_URL", "").strip()
    sync_url = os.getenv("DATABASE_URL", "").strip()

    if (not async_url) and sync_url:
        if sync_url.startswith("postgresql://"):
            os.environ["ASYNC_DATABASE_URL"] = _mk_async(sync_url)
        elif sync_url.startswith("postgresql+psycopg://"):
            base_sync = "postgresql://" + sync_url[len("postgresql+psycopg://") :]
            os.environ["ASYNC_DATABASE_URL"] = _mk_async(base_sync)

    if os.getenv("ASYNC_DATABASE_URL"):
        os.environ["ASYNC_DATABASE_URL"] = _ensure_ssl(os.environ["ASYNC_DATABASE_URL"])
        if os.environ["ASYNC_DATABASE_URL"].startswith("postgresql://") or os.environ[
            "ASYNC_DATABASE_URL"
        ].startswith("postgresql+psycopg://"):
            os.environ["ASYNC_DATABASE_URL"] = _mk_async(os.environ["ASYNC_DATABASE_URL"])

    if os.getenv("DATABASE_URL"):
        os.environ["DATABASE_URL"] = _ensure_ssl(os.environ["DATABASE_URL"])


def _mask_dsn(dsn: Optional[str]) -> str:
    """
    Return a masked DSN that never prints secrets.
    Examples:
      postgresql+asyncpg://user:****@host:5432/db?ssl=require
      SET
      NOT SET
    """
    if not dsn:
        return "NOT SET"
    dsn = str(dsn).strip()
    if not dsn:
        return "NOT SET"
    if "://" not in dsn:
        return "SET"
    try:
        scheme, rest = dsn.split("://", 1)
        if "@" not in rest:
            return "SET"
        creds, host = rest.split("@", 1)
        if ":" in creds:
            user = creds.split(":", 1)[0]
            return f"{scheme}://{user}:****@{host}"
        return f"{scheme}://****@{host}"
    except Exception:
        return "SET"


