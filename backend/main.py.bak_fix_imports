def generate_unique_id(route: APIRoute) -> str:
    tag = route.tags[0] if route.tags else "default"
    methods = "-".join(sorted((route.methods or [])))
    return f"{tag}:{route.name}:{methods}:{route.path}".replace("/", "_").replace("{", "").replace("}", "")


