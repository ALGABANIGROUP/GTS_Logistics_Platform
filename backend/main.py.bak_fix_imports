@agreement_router.post("/agreement/sign")
async def sign_partner_agreement(
    payload: Dict[str, Any] = Body(default_factory=dict),
    user: Dict[str, Any] = Depends(get_current_user),
):
    role = (user.get("effective_role") or user.get("role") or "").strip().lower()
    admin_roles = {"admin", "system_admin", "super_admin", "owner"}

    agreement_version = payload.get("agreementVersion") or payload.get("agreement_version")
    signature_name = (payload.get("signatureName") or payload.get("signature_name") or "").strip()

    if not agreement_version:
        raise HTTPException(status_code=400, detail="Missing agreementVersion")
    if not signature_name:
        raise HTTPException(status_code=400, detail="Missing signatureName")

    if role == "partner":
        if not payload.get("checkboxRevenue"):
            raise HTTPException(status_code=400, detail="Missing checkboxRevenue")
        if not payload.get("checkboxConfidentiality"):
            raise HTTPException(status_code=400, detail="Missing checkboxConfidentiality")
        if not payload.get("checkboxMisuse"):
            raise HTTPException(status_code=400, detail="Missing checkboxMisuse")

    if role not in admin_roles and role != "partner":
        raise HTTPException(status_code=403, detail="Forbidden")

    record = _PARTNER_AGREEMENT_SIGNATURES.setdefault(
        agreement_version,
        {"version": agreement_version, "partner_signature": None, "admin_signature": None},
    )
    signature = {
        "name": signature_name,
        "user_id": user.get("id"),
        "email": user.get("email"),
        "role": role,
        "signed_at": datetime.now(timezone.utc).isoformat(),
    }

    if role in admin_roles:
        record["admin_signature"] = signature
    else:
        record["partner_signature"] = signature

    activated = bool(record.get("partner_signature") and record.get("admin_signature"))

    return {
        "ok": True,
        "activated": activated,
        "agreementVersion": agreement_version,
        "signatures": {
            "partner": record.get("partner_signature"),
            "admin": record.get("admin_signature"),
        },
    }


