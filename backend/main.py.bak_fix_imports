def _policy_context(user: Dict[str, Any]) -> tuple[str, set[str]]:
    if not isinstance(user, dict):
        role = getattr(user, "effective_role", None) or getattr(user, "role", None) or "user"
        features = getattr(user, "features", None) or []
    else:
        role = user.get("effective_role") or user.get("role") or "user"
        features = user.get("features") or []

    if isinstance(role, str):
        role = role.lower()

    if isinstance(features, str):
        features_set = {features}
    else:
        features_set = set(features)

    return role, features_set


