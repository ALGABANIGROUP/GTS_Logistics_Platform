def _is_prod() -> bool:
    env = (os.getenv("ENV") or "").strip().lower()
    if env:
        if env in ("prod", "production"):
            return True
        if env in ("dev", "development", "staging", "test"):
            return False

    render_flag = (os.getenv("RENDER") or "").strip().lower()
    if render_flag in ("1", "true", "yes"):
        return True

    is_prod_env = os.getenv("IS_PRODUCTION")
    if is_prod_env is not None:
        flag = is_prod_env.strip().lower()
        if flag in ("1", "true", "yes", "prod", "production"):
            return True
        if flag in ("0", "false", "no", "dev", "development", "staging", "test"):
            return False

    env2 = (os.getenv("ENVIRONMENT") or os.getenv("APP_ENV") or "").strip().lower()
    if env2 in ("prod", "production"):
        return True

    return False


def _is_dev() -> bool:
    env = (os.getenv("ENV") or os.getenv("ENVIRONMENT") or os.getenv("APP_ENV") or "").strip().lower()
    if not env:
        return True
    return env in ("dev", "development", "local")


