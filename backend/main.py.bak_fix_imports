async def _create_session_id(user_id: int, user_agent: str) -> Optional[int]:
    try:
        from backend.database.connection import SessionLocal  # type: ignore
        from backend.admin_control.models import Session as AdminSession  # type: ignore

        async with SessionLocal() as session:
            obj = AdminSession(
                user_id=int(user_id),
                last_seen_at=datetime.now(timezone.utc),
                ip=None,
                user_agent=user_agent,
                revoked_at=None,
            )
            session.add(obj)
            await session.commit()
            await session.refresh(obj)
            return int(obj.id)
    except Exception:
        return None


async def _resolve_dev_role(requested: Optional[str]) -> str:
    if requested:
        normalized = str(requested).strip().lower()
        if normalized in _DEV_ALLOWED_ROLES:
            return normalized
        raise HTTPException(
            status_code=400,
            detail="role must be one of: " + "|".join(_DEV_ALLOWED_ROLES),
        )
    try:
        from backend.database.connection import SessionLocal  # type: ignore
        from backend.models.user import User  # type: ignore

        async with SessionLocal() as session:  # type: ignore
            res = await session.execute(select(User.role).where(User.id == DEV_SUPER_ADMIN_ID))
            role = res.scalar_one_or_none()
            if role and isinstance(role, str):
                normalized = role.strip().lower()
                if normalized in _DEV_ALLOWED_ROLES:
                    return normalized
    except Exception:
        pass
    return "super_admin"


@dev_auth_router.get("/auth/dev-token")
async def _dev_token(role: Optional[str] = None, secret: Optional[str] = None):
    if not DEV_MODE:
        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="Not found")
    if secret is not None and secret not in (DEV_SECRET, "dev-secret"):
        raise HTTPException(status_code=401, detail="invalid dev secret")
    effective_role = await _resolve_dev_role(role)

    session_id = await _create_session_id(1, "dev-token")

    token = create_access_token(
        subject=1,
        email=f"dev+{effective_role}@local.invalid",
        role=effective_role,
        expires_delta=timedelta(minutes=60 * 24),
        session_id=session_id,
    )
    return {"access_token": token, "token_type": "bearer", "role": effective_role}


