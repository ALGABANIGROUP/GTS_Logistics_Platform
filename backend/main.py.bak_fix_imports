class AIBot(Protocol):
    name: str

    async def run(self, payload: dict) -> dict: ...
    async def status(self) -> dict: ...
    async def config(self) -> dict: ...
    async def process_message(self, message: str, context: Optional[dict] = None) -> dict: ...


class BaseBot:
    async def run(self, payload: dict) -> dict:
        """Default run stub — subclasses should override."""
        raise NotImplementedError("Bot must implement run(payload: dict) -> dict")

    async def status(self) -> dict:
        """Default status stub — subclasses may override."""
        return {"ok": True, "role": getattr(self, "name", "base_bot")}

    async def config(self) -> dict:
        """Default config stub — subclasses may override."""
        return {}

    async def process_message(self, message: str, context: Optional[dict] = None) -> dict:
        payload = {"message": message, "context": context or {}}
        return await self.run(payload)


class _AIRegistry:
    def __init__(self) -> None:
        self._bots: Dict[str, AIBot] = {}

    def register(self, bot: AIBot) -> None:
        self._bots[bot.name] = bot

    def get(self, name: str) -> AIBot:
        if name not in self._bots:
            raise KeyError(name)
        return self._bots[name]

    def list(self) -> Dict[str, str]:
        return {k: v.__class__.__name__ for k, v in self._bots.items()}


