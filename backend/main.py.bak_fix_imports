@app.get("/dev/token", include_in_schema=False)
async def get_dev_token(role: str = "user", secret: Optional[str] = None):
    if IS_PRODUCTION:
        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="Not found")
    if not DEV_MODE:
        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="Not found")
    if secret is not None and secret not in (DEV_SECRET, "dev-secret"):
        raise HTTPException(status_code=401, detail="invalid dev secret")
    if role not in ("user", "manager", "admin", "partner"):
        raise HTTPException(status_code=400, detail="role must be one of: user|manager|admin|partner")

    session_id = await _create_session_id(1, "dev-token")
    token = create_access_token(
        subject=1,
        email="dev@gts.local",
        role=role,
        expires_delta=timedelta(minutes=60 * 24),
        session_id=session_id,
    )
    return {"access_token": token, "token_type": "bearer", "role": role}


@app.get("/healthz/db", include_in_schema=False)
async def healthz_db():
    session_factory = _async_session_ctx or get_async_session
    if session_factory is None:
        raise HTTPException(status_code=500, detail="Database session not available")
    async with wrap_session_factory(session_factory) as session:
        try:
            result = await session.execute(text("SELECT 1"))
            val = result.scalar()
            if val != 1:
                raise Exception("DB returned unexpected value")
        except Exception as e:
            raise HTTPException(status_code=500, detail=f"DB health check failed: {e}")
    return {"ok": True, "detail": "database connection healthy"}


@app.get("/healthz/vizion", include_in_schema=False)
async def healthz_vizion():
    if _vdb is None:
        raise HTTPException(status_code=500, detail="Vizion DB provider not available")
    try:
        maybe_result = _vdb.ping()
        result = await maybe_result if asyncio.iscoroutine(maybe_result) else maybe_result
        if not result.get("ok", False):
            raise Exception("Vizion ping returned not ok")
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Vizion health check failed: {e}")
    return {"ok": True, "detail": "vizion eye connection healthy"}
