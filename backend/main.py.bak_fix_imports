async def _check_tables(db: AsyncSession, tables: List[str]) -> Dict[str, Any]:
    try:
        from sqlalchemy import inspect

        def _inspect_sync(session_or_conn):
            try:
                bind = session_or_conn.get_bind()
            except Exception:
                bind = session_or_conn
            inspector = inspect(bind)
            return set(inspector.get_table_names())

        if hasattr(db, "run_sync"):
            existing = await db.run_sync(_inspect_sync)  # type: ignore[call-arg]
        else:
            existing = _inspect_sync(db)
        missing = sorted(set(tables) - existing)
        return {"ok": len(missing) == 0, "missing": missing}
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


def _is_system_admin(user: Dict[str, Any]) -> bool:
    role = str(user.get("effective_role") or user.get("role") or "").strip().lower()
    return role in {"admin", "system_admin", "super_admin", "owner"}


async def _compute_readiness(
    db: Optional[AsyncSession],
):
    checks: Dict[str, Any] = {}

    # DB check
    if db is None:
        checks["db"] = {"ok": False, "error": "DB session unavailable"}
    else:
        try:
            from sqlalchemy import text

            res = db.execute(text("SELECT 1"))
            if asyncio.iscoroutine(res):
                res = await res
            checks["db"] = {"ok": res.scalar() == 1}
        except Exception as exc:
            checks["db"] = {"ok": False, "error": str(exc)}

    # Bots check
    try:
        expected = set(bot_permissions.BOT_POLICIES.keys())
        registered = set(ai_registry.list().keys())
        missing = sorted(expected - registered)
        checks["bots"] = {"ok": len(missing) == 0, "missing": missing}
    except Exception as exc:
        checks["bots"] = {"ok": False, "error": str(exc)}

    # Email tables check
    email_tables = [
        "mailboxes",
        "mailbox_credentials",
        "email_threads",
        "email_messages",
        "email_attachments",
        "email_audit_logs",
        "mailbox_requests",
    ]
    if db is None:
        checks["email"] = {"ok": False, "error": "DB session unavailable"}
    else:
        checks["email"] = await _check_tables(db, email_tables)

    ok = all(bool(v.get("ok")) for v in checks.values())
    return {"ok": ok, "checks": checks}


