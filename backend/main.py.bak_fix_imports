async def _warn_missing_auth_tables() -> None:
    if IS_PRODUCTION:
        return

    expected = {"sessions", "refresh_tokens"}
    try:
        session_factory = _async_session_ctx or get_async_session
        if session_factory is None:
            print("[startup] WARN: DB session helper missing; auth table check skipped.")
            return
        async with wrap_session_factory(session_factory) as session:
            res = await session.execute(
                text("SELECT table_name FROM information_schema.tables WHERE table_schema='public'")
            )
            found = {row[0] for row in res.fetchall() if row and row[0]}
            missing = sorted(expected - found)
            if missing:
                print(f"[startup] WARN: auth tables missing: {missing}. Run Alembic upgrade.")
    except Exception as exc:
        print(f"[startup] WARN: auth table check failed: {exc}")


@app.on_event("startup")
async def on_startup():
    global _vdb, _ops_task, _docs_task, _email_poll_task

    _normalize_db_env()
    db_url = _resolve_db_url()
    if db_url:
        os.environ["ASYNC_DATABASE_URL"] = db_url

    # SECURITY: never print raw DSN (it may include credentials)
    print(f"[startup] ASYNC_DATABASE_URL -> {_mask_dsn(os.getenv('ASYNC_DATABASE_URL'))}")

    try:
        if _init_unified_engines is not None:
            _init_unified_engines()
            print("[startup] unified DB engines initialized")
        else:
            print("[startup] unified DB engines not available (config.py not updated yet)")
    except Exception as e:
        print(f"[startup] WARN: init_engines failed: {e}")

    await _warn_missing_auth_tables()

    provider = _try_import_vizion_db()
    if provider is not None:
        prov = provider
        try:
            if hasattr(prov, "connect") and callable(getattr(prov, "connect")):
                maybe_conn = prov.connect()
                conn = await maybe_conn if asyncio.iscoroutine(maybe_conn) else maybe_conn
                try:
                    setattr(prov, "db", conn)
                except Exception:
                    pass
                _vdb = prov
                app.state.vdb = prov
                await vizion_log_event("vizion_eye", "connected", enabled=True, provider="vizion_eye.module")
            elif hasattr(prov, "db"):
                _vdb = prov
                app.state.vdb = prov
                await vizion_log_event("vizion_eye", "connected (shim)", enabled=True, provider="vizion_eye.shim")
        except Exception as e:
            print(f"[startup] WARN: provider.connect() failed: {e}")

    register_core_bots()
    print("[startup] AI core bots registered:", ai_registry.list())
    try:
        registry_bots = set(ai_registry.list().keys())
        policy_bots = set(bot_permissions.BOT_POLICIES.keys())
        missing_in_registry = sorted(policy_bots - registry_bots)
        missing_in_policy = sorted(registry_bots - policy_bots)
