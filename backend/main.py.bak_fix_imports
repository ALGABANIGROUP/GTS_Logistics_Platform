@system_status_router.get("/database/stats")
async def database_stats(
    user: Dict[str, Any] = Depends(get_current_user),
    db: Optional[AsyncSession] = Depends(_get_optional_db),
):
    if not _is_system_admin(user):
        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail="Admin access required")
    try:
        from sqlalchemy import inspect

        def _inspect(conn):
            inspector = inspect(conn)
            return inspector.get_table_names()

        if db is None:
            return {"status": "unavailable", "reason": "db session unavailable", "details": None}
        tables = await asyncio.wait_for(db.run_sync(_inspect), timeout=2.0)
        return {
            "status": "ok",
            "engine": str(db.get_bind().dialect.name),
            "total_tables": len(tables),
        }
    except asyncio.TimeoutError:
        return {"status": "unavailable", "reason": "db timeout", "details": None}
    except Exception:
        return {"status": "unavailable", "reason": "db error", "details": None}


