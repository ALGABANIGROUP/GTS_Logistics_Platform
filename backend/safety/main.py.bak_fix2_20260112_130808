    async def _update_safety_metrics(self):
        """"Speak a tragedy"
        try:
            # Account must be an accident
            if self.active_incidents:
                last_incident = max(self.active_incidents, key=lambda x: x.reported_at)
                days_without = (datetime.utcnow() - last_incident.reported_at).days
                self.safety_metrics["days_without_accident"] = days_without

        except Exception as e:
            logger.error(f"Safety metrics update failed: {str(e)}")

    async def report_incident(
        self,
        incident_type: str,
        severity: str,
        description: str,
        location: str,
        reporter: str,
        injured_persons: Optional[List[Dict[str, Any]]] = None,
        witnesses: Optional[List[str]] = None,
    ) -> Dict[str, Any]:
        """"Report an accident"
        try:
            # Verify the validity of the entries
            if incident_type not in [it.value for it in IncidentType]:
                return {"error": f"Invalid incident type: {incident_type}"}

            if severity not in [s.value for s in IncidentSeverity]:
                return {"error": f"Invalid severity: {severity}"}

            # Create multiple incidents
            incident = IncidentReport(
                id=f"INC_{datetime.utcnow().strftime('%Y%m%d_%H%M%S')}",
                type=IncidentType(incident_type),
                severity=IncidentSeverity(severity),
                description=description,
                location=location,
                reported_by=reporter,
                reported_at=datetime.utcnow(),
                injured_persons=injured_persons or [],
                witnesses=witnesses or [],
                immediate_actions=[""Ezzata", "first aid kit",
                investigation_status="reported",
            )

            # I don't want to talk
            self.active_incidents.append(incident)
            self.safety_metrics["total_incidents"] += 1
            self.safety_metrics["incidents_today"] += 1

            # Record incidents
            await self.incident_manager.record_incident(incident)

            # Speak and take risks
            await self.risk_predictor.update_risk_assessment(incident)

            # Please repent
            self.safety_alerts.append(
                {
                    "id": f"ALERT_{datetime.utcnow().strftime('%Y%m%d_%H%M%S')}",
                    "type": "incident",
                    "severity": severity,
                    "title": f"accident {incident_type} q {location}",
                    "description": description,
                    "incident_id": incident.id,
                    "timestamp": datetime.utcnow().isoformat(),
                }
            )

            logger.info(f" Incident {incident.id} reported and processed")

            return {
                "incident_id": incident.id,
                "status": "reported",
                "timestamp": incident.reported_at.isoformat(),
            }

        except Exception as e:
            logger.error(f"Incident reporting failed: {str(e)}")
            return {"error": str(e)}

    async def get_safety_dashboard(self) -> Dict[str, Any]:
        """"Take a look at this story"
        try:
            dashboard = {
                "status": self.status,
                "timestamp": datetime.utcnow().isoformat(),
                "metrics": self.safety_metrics,
                "current_alerts": len(
                    [
                        a
                        for a in self.safety_alerts
                        if datetime.fromisoformat(a["timestamp"])
                        > datetime.utcnow() - timedelta(hours=24)
                    ]
                ),
                "active_incidents": len(self.active_incidents),
                "scheduled_inspections": len(self.inspection_schedule),
                "recent_alerts": self.safety_alerts[-5:],
            }

            return dashboard

        except Exception as e:
            logger.error(f"Dashboard generation failed: {str(e)}")
            return {"error": str(e)}

    async def run(self, payload: dict) -> dict:
        """Main bot execution method"""
        try:
            action = payload.get("action", "status")

            if action == "status":
                return await self.get_status()
            elif action == "config":
                return await self.get_config()
            elif action == "dashboard":
                return await self.get_safety_dashboard()
            elif action == "report_incident":
                return await self.report_incident(
                    incident_type=payload.get("incident_type"),
                    severity=payload.get("severity"),
                    description=payload.get("description"),
                    location=payload.get("location"),
                    reporter=payload.get("reporter"),
                )
            else:
                return {"error": f"Unknown action: {action}"}

        except Exception as e:
            logger.error(f"Bot execution failed: {str(e)}")
            return {"error": str(e)}

    async def get_status(self) -> dict:
        """"Check out my father's condition"
        return {
