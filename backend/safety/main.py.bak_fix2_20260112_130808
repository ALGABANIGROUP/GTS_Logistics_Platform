    async def _perform_compliance_checks(self):
        """Conducting inspections "
        try:
            compliance_report = await self.compliance_monitor.check_safety_compliance()

            # Tsj asha
            for issue in compliance_report.get("issues_found", []):
                if issue.get("severity") in ["high", "critical"]:
                    self.safety_alerts.append(
                        {
                            "id": f"COMPLIANCE_{datetime.utcnow().strftime('%Y%m%d_%H%M%S')}",
                            "type": "compliance",
                            "severity": issue["severity"],
                            "title": f"What it's like: {issue.get('standard_title')}",
                            "description": issue["description"],
                            "timestamp": datetime.utcnow().isoformat(),
                        }
                    )

            # Speak again
            self.safety_metrics["compliance_rate"] = compliance_report.get(
                "compliance_rate", 0.0
            )

        except Exception as e:
            logger.error(f"Compliance check failed: {str(e)}")

    async def _perform_risk_assessments(self):
        """"Risk-tat procedure"
        try:
            risk_assessment = await self.risk_predictor.assess_current_risks()
            self.risk_assessments.append(risk_assessment)

            # Take risks
            for risk in risk_assessment.get("high_risks", []):
                self.safety_alerts.append(
                    {
                        "id": f"RISK_{datetime.utcnow().strftime('%Y%m%d_%H%M%S')}",
                        "type": "risk",
                        "severity": "high",
                        "title": f"High thoughts: {risk['location']}",
                        "description": risk["description"],
                        "timestamp": datetime.utcnow().isoformat(),
                    }
                )

        except Exception as e:
            logger.error(f"Risk assessment failed: {str(e)}")

