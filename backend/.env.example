# ============================================
# GTS Logistics Platform - Environment Template
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ==================== DATABASE ====================
# PostgreSQL Database URL format:
# postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/gts_db
ASYNC_DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/gts_db

# ==================== APP SETTINGS ====================
APP_ENV=development
ENVIRONMENT=development
DEBUG=true
APP_VERSION=2.0.0
MAINTENANCE_MODE=false

# ==================== SECURITY ====================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
GTS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ==================== API KEYS ====================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Get from: https://openphone.com/developers
QUO_API_KEY=your-openphone-api-key
QUO_BASE_URL=https://api.openphone.com/v1
QUO_AUTH_SCHEME=bearer

# ==================== RATE LIMITING ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_API=1000

# ==================== REDIS (Optional) ====================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== SENTRY (Optional) ====================
# Get from: https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FORMAT=text

# ==================== UPLOADS ====================
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./uploads

# ==================== SERVER ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=1
