# Normalize line endings
* text=auto eol=lf

# Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (no eol normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.mp3 binary
*.wav binary
*.woff binary
*.woff2 binary

# Ensure Husky hooks are LF
.husky/* text eol=lf

# Ensure shell scripts and Node.js modules use LF
*.sh text eol=lf
*.mjs text eol=lf

