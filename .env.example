# Copy this file to `.env` and set real values locally or in your secret manager.
# Never commit live credentials to git.

# ============================================================
# Application
# ============================================================
APP_ENV=development
ENVIRONMENT=development
DEBUG=true
ENABLE_OPENAPI=1
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5173
API_BASE_URL=http://127.0.0.1:8000

# ============================================================
# Database
# ============================================================
PG_HOST=localhost
PG_PORT=5432
PG_DB=gts
PG_USER=gts_user
PG_PASSWORD=change-me
ASYNC_DATABASE_URL=postgresql+asyncpg://gts_user:change-me@localhost:5432/gts?ssl=require
DATABASE_URL=postgresql://gts_user:change-me@localhost:5432/gts?sslmode=require
SYNC_DATABASE_URL=postgresql://gts_user:change-me@localhost:5432/gts?sslmode=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=15
DB_POOL_TIMEOUT=20
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=600
DB_CONNECT_COMMAND_TIMEOUT=10
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=15

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============================================================
# Security / JWT
# ============================================================
SECRET_KEY=replace-with-a-32-char-min-secret
JWT_SECRET_KEY=replace-with-a-different-jwt-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-refresh-secret
ALGORITHM=HS256
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_REQUESTS_PER_MINUTE=120
ENFORCE_HTTPS=false
ENABLE_SECURITY_HEADERS=true

# ============================================================
# Email
# ============================================================
ADMIN_EMAIL=admin@example.com
SUPPORT_EMAIL=support@example.com
MAIL_FROM=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SSL=true
IMAP_USER=
IMAP_PASSWORD=
POP3_HOST=pop.example.com
POP3_PORT=995
POP3_SSL=true
POP3_USER=
POP3_PASSWORD=
EMAIL_MAILBOXES=

# ============================================================
# Payments / Integrations
# ============================================================
SUDAPAY_API_KEY=
SUDAPAY_API_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
EXTERNAL_API_URL=https://api.example.com

# ============================================================
# Optional bootstrap admin
# ============================================================
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Platform Administrator
BOOTSTRAP_ADMIN_ROLE=super_admin
BOOTSTRAP_ADMIN_FORCE_RESET=false
ENABLE_ADMIN_BOOTSTRAP_ROUTE=false

# ============================================================
# External API Keys for AI Bots (Real Data Integration)
# ============================================================

# Weather API - OpenWeatherMap (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Market Analysis API - Alpha Vantage (https://www.alphavantage.co/)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# News API - MarketAux (https://marketaux.com/)
MARKETAUX_KEY=your_marketaux_key_here

# Government/Legal API (Optional)
GOV_API_KEY=your_gov_api_key_here

# ============================================================
# Health checks
# ============================================================
HEALTHCHECK_DB_TIMEOUT_SECONDS=10
HEALTHCHECK_REDIS_TIMEOUT_SECONDS=5
HEALTHCHECK_EXTERNAL_TIMEOUT_SECONDS=10
HEALTHCHECK_INCLUDE_DETAILS=false
