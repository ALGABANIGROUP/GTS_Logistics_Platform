APP_ENV=development
DEBUG=true
ENVIRONMENT=development
APP_VERSION=2.0.0

DATABASE_URL=sqlite+aiosqlite:///./gts_logistics.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///./gts_logistics.db

JWT_SECRET_KEY=change-this-to-secure-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

OPENAI_API_KEY=your-openai-api-key
QUO_API_KEY=your-openphone-api-key

MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./uploads

LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# STRIPE_SECRET_KEY=sk_test_your-stripe-key

# PayPal (if using PayPal)
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# SUDAPAY (Local payment gateway)
# SUDAPAY_API_KEY=your-sudapay-api-key
# SUDAPAY_SECRET_KEY=your-sudapay-secret-key

# ===========================
# CARRIER API INTEGRATIONS
# ===========================

# 123Loadboard API
# LOADBOARD_API_KEY=your-123loadboard-key
# LOADBOARD_USERNAME=your-username

# DAT (North American transportation data)
# DAT_API_KEY=your-dat-api-key

# TruckerPath
# TRUCKERPATH_API_KEY=your-truckerpath-key

# ===========================
# MONITORING & ANALYTICS
# ===========================

# Application Insights (Azure)
# APPLICATION_INSIGHTS_CONNECTION_STRING=your-connection-string

# Google Analytics (if using frontend)
# GA_TRACKING_ID=GA-XXXXXXXXX

# ===========================
# BACKUP & MAINTENANCE
# ===========================

# Backup settings
# BACKUP_ENABLED=True
# BACKUP_SCHEDULE=daily
# BACKUP_RETENTION_DAYS=30

# ===========================
# NOTIFICATIONS
# ===========================

